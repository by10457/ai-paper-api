# ==============================
# 应用基础配置
# ==============================
# 应用名称，会展示在日志、OpenAPI 文档等位置。
APP_NAME="AI Paper API"

# 运行环境。
# 可选值：development、staging、production。
APP_ENV=development

# 是否开启调试模式；生产环境应设置为 false。
APP_DEBUG=true

# 是否开启代码热重载；仅建议本地开发使用。
APP_RELOAD=false

# HTTP 服务监听地址；0.0.0.0 表示监听所有网卡。
APP_HOST=0.0.0.0

# HTTP 服务监听端口。
APP_PORT=10462

# Uvicorn worker 进程数；调试模式下固定使用 1 个 worker。
# APP_DEBUG=true 时固定使用 1 个 worker，避免热重载与多进程冲突。
# APP_DEBUG=false 且未设置时，默认使用 min(CPU 核心数, 4)。
# 生产部署建议在 .env.docker 中显式设置，例如 WEB_CONCURRENCY=4。
# WEB_CONCURRENCY=4

# 是否启动定时任务和论文生成 worker。
SCHEDULER_ENABLED=true

# JWT 签名密钥；生产环境必须使用高强度随机值。
SECRET_KEY=your-secret-key-change-this-in-production

# ==============================
# MySQL 数据库配置
# ==============================
# MySQL 主机地址；Docker 访问宿主机可使用 host.docker.internal。
# Docker 部署提示：宿主机 MySQL 使用 host.docker.internal。
# 如果 MySQL 也是容器，请填写同一 Docker network 内的服务名。
MYSQL_HOST=127.0.0.1

# MySQL 服务端口。
MYSQL_PORT=3306

# MySQL 用户名。
MYSQL_USER=root

# MySQL 密码。
MYSQL_PASSWORD=your_password

# MySQL 数据库名称。
MYSQL_DB=your_database

# 每个应用 worker 的 MySQL 最小连接池数量。
# 开发环境通常只有 1 个 API 进程和 1 个任务进程，默认连接池保持轻量即可。
MYSQL_POOL_MIN=3

# 每个应用 worker 的 MySQL 最大连接池数量。
MYSQL_POOL_MAX=10

# 数据库时间字段使用的业务时区。
DB_TIMEZONE=Asia/Shanghai

# 是否在应用启动时自动创建缺失表；生产环境应保持 false。
# 推荐使用 aerich 迁移或 sql/init.sql 管理表结构。
DB_GENERATE_SCHEMAS=false

# ==============================
# Redis 配置
# ==============================
# Redis 主机地址；Docker 访问宿主机可使用 host.docker.internal。
# Docker 部署提示：宿主机 Redis 使用 host.docker.internal。
# 如果 Redis 也是容器，请填写同一 Docker network 内的服务名。
REDIS_HOST=127.0.0.1

# Redis 服务端口。
REDIS_PORT=6379

# Redis 密码；无密码时留空。
REDIS_PASSWORD=

# Redis 数据库编号。
REDIS_DB=0

# 每个应用 worker 的 Redis 最大连接数。
# 开发环境通常只有 1 个 API 进程和 1 个任务进程，默认连接数保持轻量即可。
REDIS_MAX_CONNECTIONS=20

# ==============================
# 日志配置
# ==============================
# 日志等级，可选 DEBUG、INFO、WARNING、ERROR。
LOG_LEVEL=INFO

# 日志文件输出路径。
LOG_FILE=logs/app.log

# ==============================
# 论文生成运行配置
# ==============================
# 论文生成产物的本地输出目录。
THESIS_OUTPUT_ROOT=public/output/thesis

# Chromium/Chrome 可执行文件路径，用于 Mermaid 渲染。
# 本机开发可使用 /usr/bin/google-chrome-stable；Docker 镜像通常使用 /usr/bin/chromium。
PUPPETEER_EXECUTABLE_PATH=

# 长文本生成并发上限，主要用于论文正文生成。
# 开发环境通常只有 1 个论文生成任务进程，因此这里就是本机论文生成上限。
TEXT_LONG_CONCURRENCY=16

# 短文本生成并发上限，主要用于大纲、摘要、关键词等。
TEXT_SHORT_CONCURRENCY=32

# 图片生成模型并发上限。
IMAGE_MODEL_CONCURRENCY=6

# SerpAPI 检索并发上限。
SERPAPI_CONCURRENCY=12

# Crossref 检索并发上限。
CROSSREF_CONCURRENCY=10

# 论文生成 worker 的整篇论文任务并发上限。
PAPER_GENERATION_CONCURRENCY=20

# 论文生成 worker 空闲时的 Redis 队列检查间隔秒数。
PAPER_WORKER_POLL_SECONDS=2

# 论文生成普通失败后的最大自动重试次数。
PAPER_GENERATION_MAX_RETRIES=2

# 论文生成失败后自动重试的延迟秒数。
PAPER_GENERATION_RETRY_DELAY_SECONDS=120

# ==============================
# 参考文献检索配置
# ==============================
# SerpAPI 密钥，用于搜索参考文献候选结果。
SERPAPI_KEY=

# Crossref 请求联系人邮箱，用于规范标识请求来源。
CROSSREF_MAILTO=

# ==============================
# 七牛云上传配置
# ==============================
# 七牛云 AccessKey。
QINIU_ACCESS_KEY=

# 七牛云 SecretKey。
QINIU_SECRET_KEY=

# 七牛云存储空间名称。
QINIU_BUCKET=

# 七牛云空间绑定域名，用于生成下载链接。
QINIU_DOMAIN=

# 七牛云私有下载链接有效期，单位秒。
QINIU_DOWNLOAD_EXPIRES=3600

# ==============================
# 业务系统回调配置
# ==============================
# 论文生成完成后通知上游业务系统的回调地址。
PAPER_CALLBACK_URL=http://localhost:10460/api/internal/paper/callback

# 论文生成回调签名密钥；为空时不附加签名。
PAPER_CALLBACK_SECRET=
