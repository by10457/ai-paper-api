# ==============================
# 应用基础配置
# ==============================
APP_NAME="T-FastAPI"
# development | staging | production
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=10462

# Uvicorn worker 进程数
# APP_DEBUG=true 时固定使用 1 个 worker，避免热重载与多进程冲突。
# APP_DEBUG=false 且未设置 WEB_CONCURRENCY 时，默认使用 min(CPU 核心数, 4)。
# 生产环境可显式设置，例如 WEB_CONCURRENCY=4。
# WEB_CONCURRENCY=4

# 是否启动定时任务调度器。
# 关闭后，开发环境不会在 app.py 中启动 APScheduler；
# Docker 默认 auto/all 启动模式也不会额外启动 scheduler 进程。
SCHEDULER_ENABLED=true

# Jwt 密钥
SECRET_KEY=your-secret-key-change-this-in-production

# ==============================
# MySQL 配置（使用 Tortoise-ORM）
# ==============================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=your_database

# Docker 部署连接提示：
# - MySQL 安装在宿主机：MYSQL_HOST=host.docker.internal
# - MySQL 也是 Docker 容器：MYSQL_HOST=<同一 Docker network 内的 MySQL 容器名或服务名>
# - 不要在容器部署时继续使用 127.0.0.1，容器内的 127.0.0.1 指向应用容器自身。

# MySQL 连接池配置
# 注意：这是“每个应用 worker 进程”的连接池大小。
# 理论最大 MySQL 连接数约为 worker 数 * MYSQL_POOL_MAX。
# 如果还有多台机器或多个容器副本，还需要继续乘以实例数。
# 小型项目可保持默认值；生产环境请结合 MySQL max_connections、服务实例数和接口耗时调整。
MYSQL_POOL_MIN=3
MYSQL_POOL_MAX=10

# 是否在应用启动时让 Tortoise 自动创建缺失表。
# 模板默认关闭，推荐使用 aerich 迁移或 sql/init.sql 管理表结构。
# 临时开发调试可改为 true；生产环境不要开启。
DB_GENERATE_SCHEMAS=false

# ==============================
# Redis 配置
# ==============================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Docker 部署连接提示：
# - Redis 安装在宿主机：REDIS_HOST=host.docker.internal
# - Redis 也是 Docker 容器：REDIS_HOST=<同一 Docker network 内的 Redis 容器名或服务名>
# - 不要在容器部署时继续使用 127.0.0.1，容器内的 127.0.0.1 指向应用容器自身。

# Redis 最大连接数
# 注意：这是“每个应用 worker 进程”的 Redis 连接上限。
# 理论最大 Redis 连接数约为 worker 数 * REDIS_MAX_CONNECTIONS。
# 如果还有多台机器或多个容器副本，还需要继续乘以实例数。
# 如果 Redis 用得很重，比如缓存、限流、会话、验证码，可根据监控适当调大。
REDIS_MAX_CONNECTIONS=20

# ==============================
# 日志配置
# ==============================
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==============================
# LLM / 论文生成配置
# ==============================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
THESIS_OUTLINE_MODEL=deepseek-chat
THESIS_FULLTEXT_MODEL=deepseek-reasoner
THESIS_OUTPUT_ROOT=public/output/thesis

# 12AI / Gemini 生图配置（可选）
TWELVEAI_API_KEY=
TWELVEAI_IMAGE_MODEL=gemini-3-pro-image-preview

# 参考文献检索配置（可选）
SERPAPI_KEY=
CROSSREF_MAILTO=

# 七牛云上传配置（论文生成完成后上传 docx）
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=

# 业务系统回调配置
PAPER_CALLBACK_URL=http://localhost:10460/api/internal/paper/callback
PAPER_CALLBACK_SECRET=

# 新注册用户默认积分；论文生成扣费积分。积分与余额按 1:10 折算。
DEFAULT_USER_POINTS=0
PAPER_GENERATE_POINTS=200
